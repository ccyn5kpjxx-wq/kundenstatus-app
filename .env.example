# Google Document AI
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_DOC_AI_PROJECT_ID=
GOOGLE_DOC_AI_LOCATION=eu
GOOGLE_DOC_AI_PROCESSOR_ID=

# OpenAI
OPENAI_API_KEY=
OPENAI_EXTRACTION_MODEL=gpt-4o
OPENAI_CHAT_MODEL=gpt-4o

# App
ADMIN_PASS=change-me
FLASK_SECRET_KEY=change-me
PUBLIC_BASE_URL=https://kundenstatus-app.vercel.app
SESSION_COOKIE_SECURE=0
ALLOW_INSECURE_LOCAL_LOGIN=1
LOGIN_RATE_LIMIT_MAX=8
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
LOGIN_RATE_LIMIT_LOCK_SECONDS=600
PUBLIC_FORM_RATE_LIMIT_MAX=6
PUBLIC_FORM_RATE_LIMIT_WINDOW_SECONDS=900
SESSION_IDLE_TIMEOUT_MINUTES=480
REMEMBER_LOGIN_DAYS=30
# Sicherer Standard: Erst nach dokumentierter juristischer Freigabe auf 1 setzen
# und einen eindeutigen Textstand eintragen (z. B. 2026-08-kanzlei-v1).
MIETVERTRAG_RECHTLICH_FREIGEGEBEN=0
MIETVERTRAG_TEXT_VERSION=
# Erst nach Prüfung von Anbietern, Drittlandtransfers und Löschfristen aktivieren
DATENSCHUTZ_RECHTLICH_FREIGEGEBEN=0
LEXWARE_KUNDEN_URL=
LEXWARE_RECHNUNGEN_URL=
LEXWARE_API_KEY=
LEXWARE_API_BASE_URL=https://api.lexware.io
LEXWARE_APP_BASE_URL=https://app.lexware.de
LEXWARE_TAX_RATE=19
LEXWARE_AUTO_SYNC_MINUTES=30
WERKSTATT_EMAIL_API_TOKEN=
# Eigener, enger berechtigter Schlüssel für Queue/Heartbeat/Import des Fahrzeug-Scanners
# Ohne Wert bleibt WERKSTATT_EMAIL_API_TOKEN vorübergehend als Fallback aktiv.
FAHRZEUGEINKAUF_SCANNER_API_TOKEN=
# Kommagetrennte HTTPS-Hosts, deren Inserat-Links der Scanner importieren darf
FAHRZEUGEINKAUF_ERLAUBTE_INSERAT_HOSTS=kleinanzeigen.de,mobile.de,autoscout24.de,copart.de
# Fahrzeugeinkauf: nach wie vielen Minuten ohne Poll der lokale Scanner als offline gilt
FAHRZEUGEINKAUF_SCANNER_OFFLINE_MINUTES=20
# Maximale Laufzeit einer einzelnen Scan-Anfrage, danach wird "Erneut versuchen" angeboten
FAHRZEUGEINKAUF_SCAN_TIMEOUT_MINUTES=45
# Absolute Obergrenze trotz regelmäßiger Lebenszeichen
FAHRZEUGEINKAUF_SCAN_MAX_RUNTIME_MINUTES=120

# E-Mail / Webjoker IMAP
# Zugangsdaten nur lokal in .env.local setzen, nicht committen.
MAIL_IMAP_HOST=mailhost.webjoker.biz
MAIL_IMAP_PORT=993
MAIL_IMAP_USER=
MAIL_IMAP_PASS=
MAIL_IMAP_FOLDER=INBOX
MAIL_IMAP_SSL=1
MAIL_IMAP_SEARCH=UNSEEN
MAIL_IMAP_LIMIT=30
MAIL_IMAP_MARK_SEEN=0
MAIL_IMAP_ARCHIVE_FOLDER=
MAIL_IMAP_TIMEOUT_SECONDS=20
# Empfaengerbasierte Sortierung fuer Aliase/Postfaecher.
# Format: adresse=ziel; ziel kann z.B. schaden, rechnungen, einkauf, termine, reklamation sein.
MAIL_ROUTE_ALIASES=schaden@auto-lackierzentrum.de=schaden;schadenmeldung@auto-lackierzentrum.de=schaden;versicherung@auto-lackierzentrum.de=versicherung;rechnungen@auto-lackierzentrum.de=rechnungen;rechnung@auto-lackierzentrum.de=rechnungen;belege@auto-lackierzentrum.de=belege;buchhaltung@auto-lackierzentrum.de=buchhaltung;einkauf@auto-lackierzentrum.de=einkauf;bestellung@auto-lackierzentrum.de=einkauf;termine@auto-lackierzentrum.de=termine;termin@auto-lackierzentrum.de=termine;reklamation@auto-lackierzentrum.de=reklamation;reklamationen@auto-lackierzentrum.de=reklamation

# Schadenregulierung-Mailbox
# Diese Adresse legt ihr beim Mailanbieter an, z.B. schaden@auto-lackierzentrum.de.
SCHADEN_MAIL_ADDRESS=
SCHADEN_MAIL_DISPLAY_NAME=Gärtner Karosserie & Lack - Schadenregulierung
SCHADEN_IMAP_HOST=mailhost.webjoker.biz
SCHADEN_IMAP_PORT=993
SCHADEN_IMAP_USER=
SCHADEN_IMAP_PASS=
SCHADEN_IMAP_FOLDER=INBOX
SCHADEN_IMAP_SSL=1
SCHADEN_SMTP_HOST=mailhost.webjoker.biz
SCHADEN_SMTP_PORT=587
SCHADEN_SMTP_USER=
SCHADEN_SMTP_PASS=
SCHADEN_SMTP_TLS=1
SCHADEN_SMTP_SSL=0
SCHADEN_SMTP_ATTACHMENTS=1
SCHADEN_SMTP_ATTACHMENT_LIMIT_MB=18

# Produktion / Vercel Neon Postgres
# Lokal leer lassen, dann nutzt die App data/auftraege.db.
DATABASE_URL=
UPLOAD_DIR=
PORT=5000
